---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Mikey Somatics | Your Partner in Healing">

  <!-- Hero -->
  <section class="py-24 bg-sand">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
      <div>
        <img src="/images/about-photo.png" alt="Mikey Alexander" class="rounded-2xl shadow-lg w-full" />
      </div>
      <div>
        <p class="text-sm tracking-widest uppercase text-sage mb-3">About Me</p>
        <h1 class="text-3xl md:text-4xl font-light text-forest mb-6">Your Partner in Healing</h1>
        <p class="text-charcoal/70 leading-relaxed mb-6">
          With over a decade of experience in high-pressure environments, I developed a deep understanding of the toll that stress, trauma, and chronic pain can take on the body and mind. My personal journey with PTSD and chronic pain led me to specialize in the mind-body connection, where I discovered the profound impact of somatic healing.
        </p>
        <p class="text-charcoal/70 leading-relaxed">
          Today, I offer a trauma-informed, compassionate space for individuals to safely explore emotions, release stored trauma, and rewire their brain's response to pain. My approach empowers you to feel more balanced, resilient, and deeply attuned to your healing process.
        </p>
      </div>
    </div>
  </section>

  <!-- Fun Facts -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-sm tracking-widest uppercase text-sage mb-3">A Little About Me</p>
      <h2 class="text-3xl font-light text-forest mb-12">My Quirks</h2>
      <div class="grid sm:grid-cols-3 gap-8">
        <div class="p-6">
          <p class="text-charcoal/70 leading-relaxed">I'm a Titanic history enthusiast&mdash;ask me anything about it!</p>
        </div>
        <div class="p-6">
          <p class="text-charcoal/70 leading-relaxed">I love crafting my own fragrances and blending unique scents.</p>
        </div>
        <div class="p-6">
          <p class="text-charcoal/70 leading-relaxed">I'm an AI and tech geek, always exploring the latest innovations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-24 bg-sand">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <p class="text-sm tracking-widest uppercase text-sage mb-3">Credentials</p>
      <h2 class="text-3xl font-light text-forest mb-16">Training & Certifications</h2>
      <div class="grid sm:grid-cols-3 gap-10">
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <img src="/images/aura-cert.png" alt="Aura Institute Certificate" class="w-full rounded-lg mb-6" />
          <h3 class="text-forest font-semibold mb-1">Certified Integrative Trauma Coach</h3>
          <p class="text-sm text-charcoal/60">ITP-2 &middot; Aura Institute</p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <img src="/images/embodylabs.png" alt="Embody Lab Certificate" class="w-full rounded-lg mb-6" />
          <h3 class="text-forest font-semibold mb-1">Integrative Trauma Therapy Certificate</h3>
          <p class="text-sm text-charcoal/60">The Embody Lab</p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <img src="/images/itp-cert.png" alt="Pain Reprocessing Therapy Certificate" class="w-full rounded-lg mb-6" />
          <h3 class="text-forest font-semibold mb-1">Pain Reprocessing Therapy Certificate</h3>
          <p class="text-sm text-charcoal/60">Pain Reprocessing Therapy</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-forest text-white text-center">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-light mb-6">Ready to Start Your Journey?</h2>
      <p class="text-white/70 leading-relaxed mb-10">
        I'd love to connect and learn more about what you're going through. Book a free consultation to see if we're a good fit.
      </p>
      <a href="/contact" class="inline-block bg-white text-forest px-8 py-3.5 rounded-full text-sm tracking-wide hover:bg-sand transition-colors font-medium">
        Book Free Consult
      </a>
    </div>
  </section>

</Layout>
