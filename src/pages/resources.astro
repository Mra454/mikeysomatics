---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resources | Mikey Somatics">

  <!-- Hero -->
  <section class="py-12 bg-sand">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-sm tracking-widest uppercase text-sage mb-3">Resources</p>
      <h1 class="text-3xl md:text-4xl font-light text-forest mb-4">Learn More</h1>
      <p class="text-charcoal/70 leading-relaxed max-w-2xl mx-auto">
        Explore videos, guides, and insights on somatic healing, trauma recovery, and the mind-body connection.
      </p>
    </div>
  </section>

  <!-- YouTube Videos -->
  <section class="py-16 bg-cream">
    <div class="max-w-5xl mx-auto px-6">
      <p class="text-sm tracking-widest uppercase text-sage mb-3 text-center">Videos</p>
      <h2 class="text-3xl font-light text-forest mb-10 text-center">From My Channel</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="aspect-video">
            <iframe class="w-full h-full" src="https://www.youtube.com/embed/TQiCHX2NZoM" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </div>
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="aspect-video">
            <iframe class="w-full h-full" src="https://www.youtube.com/embed/m7_Ct1oPCKk" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </div>
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="aspect-video">
            <iframe class="w-full h-full" src="https://www.youtube.com/embed/I36TB3MdDCs" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="https://www.youtube.com/channel/UCjRNB5Kpd_-shtWxiCZsMsA" target="_blank" rel="noopener noreferrer" class="inline-block bg-forest text-white px-8 py-3.5 rounded-full text-sm tracking-wide hover:bg-forest-light transition-colors">
          Visit My YouTube Channel
        </a>
      </div>
    </div>
  </section>

</Layout>